{
  "name": "markengine",
  "version": "0.1.0",
  "description": "Standalone markdown parser and renderers (HTML, React, terminal)",
  "license": "MIT",
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
